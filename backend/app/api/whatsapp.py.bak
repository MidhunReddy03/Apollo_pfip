"""
WhatsApp Bot Service for Patient Portal Integration
Handles incoming WhatsApp messages and provides patient journey updates
Can be integrated with Twilio or WhatsApp Business API
"""

from fastapi import APIRouter, Depends, HTTPException, status, Request
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select
from app.db.session import get_db
from app.models.patient import Patient
from app.models.patient_session import PatientSession
from app.models.encounter import Encounter, EncounterStatus
from datetime import datetime
import logging

logger = logging.getLogger(__name__)

router = APIRouter(prefix="/whatsapp", tags=["WhatsApp Bot"])


class WhatsAppMessage:
    """Represent incoming WhatsApp message"""
    def __init__(self, phone: str, body: str):
        self.phone = phone
        self.body = body
        self.intent = self.detect_intent()
        self.timestamp = datetime.utcnow()

    def detect_intent(self) -> str:
        """Detect user intent from message"""
        body_lower = self.body.lower().strip()
        
        if body_lower in ["hi", "hello", "hey", "start", "menu"]:
            return "greeting"
        elif body_lower in ["1", "status", "where am i", "current"]:
            return "current_status"
        elif body_lower in ["2", "next", "next steps", "what's next"]:
            return "next_steps"
        elif body_lower in ["3", "directions", "how to", "where to go", "instructions"]:
            return "directions"
        elif body_lower in ["4", "alerts", "notifications", "messages"]:
            return "notifications"
        elif body_lower in ["logout", "exit", "bye", "goodbye"]:
            return "logout"
        elif body_lower.isdigit():
            return "patient_id_entry"
        elif len(body_lower) < 20:
            return "password_entry"
        else:
            return "help_request"


class WhatsAppBot:
    """Main WhatsApp Bot Logic"""
    
    def __init__(self):
        self.sessions = {}  # phone -> patient_id mapping for current session

    async def process_message(self, phone: str, message: str, db: AsyncSession) -> str:
        """Process incoming WhatsApp message and return response"""
        msg = WhatsAppMessage(phone, message)
        
        # Handle based on intent
        if msg.intent == "greeting":
            return await self.handle_greeting(phone, db)
        elif msg.intent == "patient_id_entry":
            self.sessions[phone] = {"patient_id": int(message), "step": "awaiting_password"}
            return "Please enter your session password:"
        elif msg.intent == "password_entry":
            return await self.handle_login(phone, message, db)
        elif msg.intent == "current_status":
            return await self.handle_current_status(phone, db)
        elif msg.intent == "next_steps":
            return await self.handle_next_steps(phone, db)
        elif msg.intent == "directions":
            return await self.handle_directions(phone, db)
        elif msg.intent == "notifications":
            return await self.handle_notifications(phone, db)
        elif msg.intent == "logout":
            return await self.handle_logout(phone)
        else:
            return self.get_help_message()

    async def handle_greeting(self, phone: str, db: AsyncSession) -> str:
        """Handle greeting message"""
        if phone in self.sessions and self.sessions[phone].get("patient_id"):
            patient_id = self.sessions[phone]["patient_id"]
            result = await db.execute(
                select(Patient).where(Patient.id == patient_id)
            )
            patient = result.scalar_one_or_none()
            if patient:
                return f"""👋 Welcome back, {patient.first_name}!

What would you like to know?

1️⃣  My Current Status
2️⃣  Next Steps
3️⃣  Directions
4️⃣  Notifications

Reply with the number to choose."""
        else:
            return """👋 Welcome to Apollo DQMS Patient Portal!

Please enter your **Patient ID** to get started.
(You received this from the registration desk)"""

    async def handle_login(self, phone: str, password: str, db: AsyncSession) -> str:
        """Authenticate patient with password"""
        if phone not in self.sessions or "patient_id" not in self.sessions[phone]:
            return "Please enter your Patient ID first."

        patient_id = self.sessions[phone]["patient_id"]

        # Find session
        result = await db.execute(
            select(PatientSession).where(
                PatientSession.patient_id == patient_id,
                PatientSession.session_password == password,
                PatientSession.is_active == True,
            )
        )
        session = result.scalar_one_or_none()

        if not session or datetime.utcnow() > session.expires_at:
            return "❌ Invalid password or session expired. Please try again."

        # Get patient info
        result = await db.execute(
            select(Patient).where(Patient.id == patient_id)
        )
        patient = result.scalar_one_or_none()

        self.sessions[phone] = {"patient_id": patient_id, "authenticated": True}

        return f"""✅ Welcome, {patient.first_name}!

What would you like to know?

1️⃣  My Current Status
2️⃣  Next Steps
3️⃣  Directions
4️⃣  Notifications

Reply with the number."""

    async def handle_current_status(self, phone: str, db: AsyncSession) -> str:
        """Show patient's current status"""
        if not self._is_authenticated(phone):
            return "Please log in first by sending your Patient ID and password."

        patient_id = self.sessions[phone]["patient_id"]

        # Get active encounter
        result = await db.execute(
            select(Encounter).where(
                Encounter.patient_id == patient_id,
                Encounter.is_active == True,
                Encounter.status.in_(
                    [EncounterStatus.CHECKED_IN, EncounterStatus.IN_QUEUE, EncounterStatus.IN_PROGRESS]
                ),
            )
        )
        encounter = result.scalar_one_or_none()

        if not encounter:
            return "ℹ️ Your hospital visit has been completed. Thank you!"

        status_emoji = {
            EncounterStatus.CHECKED_IN: "✅",
            EncounterStatus.IN_QUEUE: "⏳",
            EncounterStatus.IN_PROGRESS: "🏥",
        }.get(encounter.status, "ℹ️")

        return f"""{status_emoji} Current Status

📍 Department: {encounter.department}
⏱️  Status: {encounter.status.replace('_', ' ').upper()}
🔴 Priority: {encounter.priority.upper()}
💬 Chief Complaint: {encounter.chief_complaint}

Want to know the next steps? Reply: 2"""

    async def handle_next_steps(self, phone: str, db: AsyncSession) -> str:
        """Show patient's next steps"""
        if not self._is_authenticated(phone):
            return "Please log in first."

        patient_id = self.sessions[phone]["patient_id"]

        result = await db.execute(
            select(Encounter).where(
                Encounter.patient_id == patient_id,
                Encounter.is_active == True,
                Encounter.status.in_(
                    [EncounterStatus.CHECKED_IN, EncounterStatus.IN_QUEUE, EncounterStatus.IN_PROGRESS]
                ),
            )
        )
        encounter = result.scalar_one_or_none()

        if not encounter:
            return "Your visit is complete. Thank you!"

        if encounter.tests_ordered:
            return """🧪 Next Steps

📍 Visit: Laboratory
🔬 What: Lab Tests
⏱️  Estimated Time: 30 minutes
📌 Location: 2nd Floor, Room 205

Take your registration card with you!"""
        else:
            return """⏳ Next Steps

Please wait for the doctor. 
You'll be called when it's your turn.

Current wait time: ~15 minutes"""

    async def handle_directions(self, phone: str, db: AsyncSession) -> str:
        """Provide directions to next location"""
        if not self._is_authenticated(phone):
            return "Please log in first."

        return """🗺️ Directions to Laboratory

From your current location:
1️⃣  Go to the main corridor
2️⃣  Turn right at the information desk
3️⃣  Take the elevator to 2nd Floor
4️⃣  Lab is on your right side

Total time: ~5 minutes

If you can't find it, ask any staff member!"""

    async def handle_notifications(self, phone: str, db: AsyncSession) -> str:
        """Show patient's notifications"""
        if not self._is_authenticated(phone):
            return "Please log in first."

        patient_id = self.sessions[phone]["patient_id"]

        result = await db.execute(
            select(Encounter).where(
                Encounter.patient_id == patient_id,
                Encounter.is_active == True,
            )
        )
        encounter = result.scalar_one_or_none()

        if not encounter:
            return "No new notifications."

        notifications = []
        
        if encounter.tests_ordered:
            notifications.append("🧪 Lab tests have been ordered for you")
        
        if encounter.status == EncounterStatus.IN_PROGRESS:
            notifications.append("🏥 Doctor is ready for you")

        if not notifications:
            notifications.append("ℹ️ No new updates")

        msg = "📬 Your Notifications:\n\n"
        for i, notif in enumerate(notifications, 1):
            msg += f"{i}. {notif}\n"

        return msg

    async def handle_logout(self, phone: str) -> str:
        """Logout patient session"""
        if phone in self.sessions:
            del self.sessions[phone]
        return "👋 You've been logged out. Thank you for using Apollo DQMS!"

    def _is_authenticated(self, phone: str) -> bool:
        """Check if user is authenticated"""
        return (
            phone in self.sessions
            and self.sessions[phone].get("authenticated", False)
        )

    def get_help_message(self) -> str:
        """Return help message"""
        return """ℹ️ I didn't understand that.

Commands:
1️⃣  My Current Status
2️⃣  Next Steps
3️⃣  Directions
4️⃣  Notifications

Reply with a number or ask for help."""


# Initialize bot
whatsapp_bot = WhatsAppBot()


@router.post("/webhook")
async def whatsapp_webhook(request: Request, db: AsyncSession = Depends(get_db)):
    """
    Receive and process WhatsApp messages
    This is called by Twilio or WhatsApp Business API
    """
    try:
        data = await request.json()

        # Extract phone number and message
        phone = data.get("from", "")
        message = data.get("body", "")

        if not phone or not message:
            raise HTTPException(status_code=400, detail="Missing phone or message")

        # Process message
        response = await whatsapp_bot.process_message(phone, message, db)

        return {
            "status": "success",
            "response": response,
            "timestamp": datetime.utcnow(),
        }
    except Exception as e:
        logger.error(f"WhatsApp webhook error: {e}")
        return {
            "status": "error",
            "response": "Sorry, something went wrong. Please try again.",
        }


@router.get("/test/{phone}/{message}")
async def test_whatsapp_message(
    phone: str, message: str, db: AsyncSession = Depends(get_db)
):
    """
    Test WhatsApp bot without actual Twilio integration
    Example: /api/v1/whatsapp/test/+919876543210/hi
    """
    response = await whatsapp_bot.process_message(phone, message, db)
    return {
        "phone": phone,
        "message": message,
        "response": response,
        "timestamp": datetime.utcnow(),
    }


@router.post("/send")
async def send_whatsapp_message(
    phone: str, message: str, db: AsyncSession = Depends(get_db)
):
    """
    Send WhatsApp message to patient (called by system)
    Example: When doctor assigns tests, system sends notification
    """
    # This would integrate with Twilio to actually send the message
    # For now, just return success
    logger.info(f"Sending WhatsApp to {phone}: {message}")
    return {
        "status": "success",
        "phone": phone,
        "message": message,
        "sent_at": datetime.utcnow(),
    }
